# Copy to .env and edit before `docker compose up -d --build`.

# REQUIRED: long random string for signing login tokens.
# Generate one with:  openssl rand -hex 32
DENNY_SECRET_KEY=replace-with-a-long-random-string

# First-run admin account (only used when the database is empty).
DENNY_ADMIN_USERNAME=admin
DENNY_ADMIN_PASSWORD=change-this-please

# Public HTTP port (only used by the --profile http / nginx setup).
DENNY_HTTP_PORT=80

# --- Automatic HTTPS (only used by the --profile https / Caddy setup) ---
# Your domain must already point (A/AAAA record) at this server, ports 80+443 open.
# DENNY_DOMAIN=panel.example.com
# DENNY_ACME_EMAIL=you@example.com

# Optional: only set if NOT using the bundled nginx proxy (e.g. a separate
# domain for the API). Baked into the frontend at build time.
# NEXT_PUBLIC_BACKEND_WS=wss://panel.example.com

# --- Security (sane defaults; override only if you know why) ---
# DENNY_ENABLE_DOCS=false          # expose /docs OpenAPI UI (off for internet)
# DENNY_MAX_UPLOAD_MB=100          # file-manager upload size cap
# DENNY_LOGIN_MAX_ATTEMPTS=10      # failed logins per IP before lockout
# DENNY_LOGIN_WINDOW_SECONDS=300   # lockout window
# DENNY_FTP_HOME_ROOT=/home        # FTP/SFTP account home dirs confined here
# DENNY_ALLOW_INSECURE_SECRET=true # DEV ONLY — never set in production
# Number of trusted reverse proxies in front of the API. Behind the bundled
# nginx/Caddy proxy this MUST be 1 so the real client IP is used for the login
# rate-limit; leave 0 if the API is exposed directly (ignores X-Forwarded-For).
DENNY_TRUSTED_PROXIES=1

# --- AI assistant (optional) ---
# Talks to a NewAPI / OpenAI-compatible endpoint. The key is read ONLY by the
# backend and is NEVER sent to the browser — the panel calls its own
# /api/assistant/chat proxy. Leave the key empty to disable the assistant.
# DENNY_ASSISTANT_API_KEY=sk-...
# DENNY_ASSISTANT_BASE_URL=https://your-newapi.example.com/v1
# DENNY_ASSISTANT_MODEL=gpt-4o-mini

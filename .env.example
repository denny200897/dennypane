# Copy to .env and edit before `docker compose up -d --build`.

# REQUIRED: long random string for signing login tokens.
# Generate one with:  openssl rand -hex 32
DENNY_SECRET_KEY=replace-with-a-long-random-string

# First-run admin account (only used when the database is empty).
DENNY_ADMIN_USERNAME=admin
DENNY_ADMIN_PASSWORD=change-this-please

# Public HTTP port for the panel (behind your own TLS terminator if you want HTTPS).
DENNY_HTTP_PORT=80

# Optional: only set if NOT using the bundled nginx proxy (e.g. a separate
# domain for the API). Baked into the frontend at build time.
# NEXT_PUBLIC_BACKEND_WS=wss://panel.example.com

# --- Security (sane defaults; override only if you know why) ---
# DENNY_ENABLE_DOCS=false          # expose /docs OpenAPI UI (off for internet)
# DENNY_MAX_UPLOAD_MB=100          # file-manager upload size cap
# DENNY_LOGIN_MAX_ATTEMPTS=10      # failed logins per IP before lockout
# DENNY_LOGIN_WINDOW_SECONDS=300   # lockout window
# DENNY_ALLOW_INSECURE_SECRET=true # DEV ONLY — never set in production
